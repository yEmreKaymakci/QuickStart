@using QuickStart.WebUI.Dtos.Notification
@model List<ResultNotificationWithNotificationTypeDto>
@{
    ViewData["Title"] = "Bildirim Yönetimi";
    Layout = "~/Views/_AdminLayout/Index.cshtml";
    var total = Model.Count;
    var unread = Model.Count(x => !x.IsRead);
    var read = Model.Count(x => x.IsRead);
    var typeGroups = Model.GroupBy(x => x.NotificationTypeName).Count();
}

<div class="space-y-6">

    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        <div class="bg-dark-bg-card border border-gray-800 rounded-custom p-4 flex items-center gap-4">
            <div class="w-10 h-10 rounded-lg bg-accent-blue/10 flex items-center justify-center shrink-0">
                <i class="mdi mdi-bell-outline text-accent-blue text-lg"></i>
            </div>
            <div>
                <p class="text-2xl font-bold text-white">@total</p>
                <p class="text-xs text-gray-500 mt-0.5">Toplam</p>
            </div>
        </div>
        <div class="bg-dark-bg-card border border-gray-800 rounded-custom p-4 flex items-center gap-4">
            <div class="w-10 h-10 rounded-lg bg-yellow-500/10 flex items-center justify-center shrink-0">
                <i class="mdi mdi-clock-outline text-yellow-400 text-lg"></i>
            </div>
            <div>
                <p class="text-2xl font-bold text-white">@unread</p>
                <p class="text-xs text-gray-500 mt-0.5">Okunmadı</p>
            </div>
        </div>
        <div class="bg-dark-bg-card border border-gray-800 rounded-custom p-4 flex items-center gap-4">
            <div class="w-10 h-10 rounded-lg bg-green-500/10 flex items-center justify-center shrink-0">
                <i class="mdi mdi-check-circle-outline text-green-400 text-lg"></i>
            </div>
            <div>
                <p class="text-2xl font-bold text-white">@read</p>
                <p class="text-xs text-gray-500 mt-0.5">Okundu</p>
            </div>
        </div>
        <div class="bg-dark-bg-card border border-gray-800 rounded-custom p-4 flex items-center gap-4">
            <div class="w-10 h-10 rounded-lg bg-accent-purple/10 flex items-center justify-center shrink-0">
                <i class="mdi mdi-tag-multiple-outline text-accent-purple text-lg"></i>
            </div>
            <div>
                <p class="text-2xl font-bold text-white">@typeGroups</p>
                <p class="text-xs text-gray-500 mt-0.5">Tür Sayısı</p>
            </div>
        </div>
    </div>

    <div class="bg-dark-bg-card rounded-custom border border-gray-800 shadow-xl overflow-hidden">

        <div class="p-5 border-b border-gray-800 flex flex-col sm:flex-row gap-3 justify-between items-start sm:items-center flex-wrap">
            <div>
                <h2 class="text-xl font-bold text-white">Bildirimler</h2>
                <p class="text-sm text-gray-400 mt-0.5">Platformdaki bildirimleri buradan yönetin.</p>
            </div>
            <div class="flex items-center gap-2 flex-wrap">
                <a href="/AdminNotification/CreateNotification" class="inline-flex items-center gap-2 bg-accent-blue hover:bg-blue-600 text-white px-4 py-2 rounded-custom transition-all-custom text-sm font-medium shadow-lg shadow-blue-500/20">
                    <i class="mdi mdi-plus"></i> Yeni Bildirim
                </a>
            </div>
        </div>

        <div id="pageFilterPanel" class="hidden px-5 py-3 border-b border-gray-800 bg-black/10 flex flex-col sm:flex-row gap-3 items-start sm:items-center flex-wrap">
            <input id="searchInput" type="text" class="hidden" />
            <div class="flex items-center gap-1.5 text-xs text-gray-500 font-medium shrink-0">
                <i class="mdi mdi-filter-outline"></i> Filtreler:
            </div>
            <select id="typeFilter" class="bg-dark-bg-deep border border-gray-700 rounded-lg px-3 py-2 text-sm text-gray-300 focus:ring-1 focus:ring-accent-blue outline-none">
                <option value="">Tüm Türler</option>
                @foreach (var type in Model.Select(x => x.NotificationTypeName).Distinct())
                {
                    <option value="@type">@type</option>
                }
            </select>
            <select id="statusFilter" class="bg-dark-bg-deep border border-gray-700 rounded-lg px-3 py-2 text-sm text-gray-300 focus:ring-1 focus:ring-accent-blue outline-none">
                <option value="">Tüm Durumlar</option>
                <option value="unread">Okunmadı</option>
                <option value="read">Okundu</option>
            </select>
            <button onclick="filterRows()" class="inline-flex items-center gap-1.5 bg-accent-blue/10 hover:bg-accent-blue/20 text-accent-blue px-3 py-2 rounded-lg text-xs font-semibold transition-all-custom">
                <i class="mdi mdi-check"></i> Uygula
            </button>
            <button onclick="resetFilters()" class="inline-flex items-center gap-1.5 bg-gray-700/50 hover:bg-gray-700 text-gray-400 px-3 py-2 rounded-lg text-xs font-semibold transition-all-custom">
                <i class="mdi mdi-refresh"></i> Sıfırla
            </button>
        </div>


        <div id="bulkBar" class="hidden px-5 py-2.5 border-b border-gray-800 bg-accent-blue/5 flex items-center gap-3">
            <span id="selectedCount" class="text-sm font-medium text-accent-blue"></span>
            <button onclick="bulkDelete()" class="inline-flex items-center gap-1 bg-red-500/10 hover:bg-red-500/20 text-red-400 px-3 py-1.5 rounded-md text-xs font-bold transition-all-custom">
                <i class="mdi mdi-delete"></i> Seçilenleri Sil
            </button>
            <button onclick="clearSelection()" class="text-xs text-gray-500 hover:text-gray-300 transition-colors ml-auto">
                Seçimi Kaldır
            </button>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-left whitespace-nowrap">
                <thead>
                    <tr class="text-gray-500 text-xs font-bold uppercase tracking-wider bg-black/20">
                        <th class="px-5 py-3.5">
                            <input type="checkbox" id="selectAll" class="w-3.5 h-3.5 rounded border-gray-600 bg-dark-bg-deep text-accent-blue focus:ring-accent-blue cursor-pointer" />
                        </th>
                        <th class="px-5 py-3.5 cursor-pointer hover:text-gray-300 transition-colors select-none" onclick="sortTable('title')">
                            Başlık <i class="mdi mdi-unfold-more-horizontal opacity-40"></i>
                        </th>
                        <th class="px-5 py-3.5">İçerik</th>
                        <th class="px-5 py-3.5">E-posta</th>
                        <th class="px-5 py-3.5 cursor-pointer hover:text-gray-300 transition-colors select-none" onclick="sortTable('type')">
                            Tür <i class="mdi mdi-unfold-more-horizontal opacity-40"></i>
                        </th>
                        <th class="px-5 py-3.5 cursor-pointer hover:text-gray-300 transition-colors select-none" onclick="sortTable('status')">
                            Durum <i class="mdi mdi-unfold-more-horizontal opacity-40"></i>
                        </th>
                        <th class="px-5 py-3.5 text-right">İşlemler</th>
                    </tr>
                </thead>
                <tbody id="notifTableBody" class="divide-y divide-gray-800/60">
                    @foreach (var item in Model)
                    {
                        var typeColors = new Dictionary<string, string>
                        {
                            {"Sipariş", "bg-blue-500/10 text-blue-400"},
                            {"Mesaj", "bg-accent-purple/10 text-accent-purple"},
                            {"Kampanya", "bg-orange-500/10 text-orange-400"},
                            {"Güncelleme", "bg-cyan-500/10 text-cyan-400"},
                        };
                        var badgeClass = typeColors.ContainsKey(item.NotificationTypeName ?? "") ? typeColors[item.NotificationTypeName] : "bg-gray-700/40 text-gray-400";

                        <tr class="notif-row hover:bg-white/5 transition-all-custom @(item.IsRead ? "opacity-60" : "")"
                            data-title="@item.Title.ToLower()"
                            data-content="@item.Content.ToLower()"
                            data-email="@(item.Email?.ToLower() ?? "")"
                            data-type="@item.NotificationTypeName"
                            data-status="@(item.IsRead ? "read" : "unread")">
                            <td class="px-5 py-3.5">
                                <input type="checkbox" class="row-check w-3.5 h-3.5 rounded border-gray-600 bg-dark-bg-deep text-accent-blue focus:ring-accent-blue cursor-pointer" data-id="@item.NotificationId" />
                            </td>
                            <td class="px-5 py-3.5 text-sm font-medium text-white max-w-[160px]">
                                <div class="truncate">@item.Title</div>
                            </td>
                            <td class="px-5 py-3.5 text-sm text-gray-400 max-w-[200px]">
                                <button onclick="openPreview('@item.NotificationId', '@Html.Raw(item.Title.Replace("'","&#39;"))', '@Html.Raw(item.Content.Replace("'","&#39;"))', '@item.Email', '@item.NotificationTypeName', @(item.IsRead ? "true" : "false"))"
                                        class="flex items-center gap-1 text-left hover:text-accent-blue transition-colors group">
                                    <span class="truncate max-w-[160px]">@item.Content</span>
                                    <i class="mdi mdi-arrow-expand text-xs opacity-0 group-hover:opacity-100 shrink-0 transition-opacity"></i>
                                </button>
                            </td>
                            <td class="px-5 py-3.5 text-xs text-gray-400 max-w-[130px]">
                                <div class="truncate">@(item.Email ?? "-")</div>
                            </td>
                            <td class="px-5 py-3.5">
                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium @badgeClass">
                                    <i class="mdi mdi-tag-outline text-[10px]"></i>
                                    @item.NotificationTypeName
                                </span>
                            </td>
                            <td class="px-5 py-3.5">
                                @if (item.IsRead)
                                {
                                    <span class="inline-flex items-center gap-1 bg-green-500/10 text-green-400 px-2 py-0.5 rounded-full text-xs font-medium">
                                        <i class="mdi mdi-check-circle text-[10px]"></i> Okundu
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center gap-1 bg-yellow-500/10 text-yellow-400 px-2 py-0.5 rounded-full text-xs font-medium">
                                        <i class="mdi mdi-clock-outline text-[10px]"></i> Okunmadı
                                    </span>
                                }
                            </td>
                            <td class="px-5 py-3.5 text-right">
                                <div class="flex items-center justify-end gap-1.5">
                                    @if (!item.IsRead)
                                    {
                                        <a href="/Notification/MarkeAsRead/@item.NotificationId" title="Okundu İşaretle" class="inline-flex items-center justify-center w-7 h-7 bg-green-500/10 text-green-400 hover:bg-green-500/20 rounded-md text-xs transition-all-custom">
                                            <i class="mdi mdi-check"></i>
                                        </a>
                                    }
                                    <a href="/AdminNotification/UpdateNotification/@item.NotificationId" title="Düzenle" class="inline-flex items-center justify-center w-7 h-7 bg-blue-500/10 text-blue-400 hover:bg-blue-500/20 rounded-md text-xs transition-all-custom">
                                        <i class="mdi mdi-pencil"></i>
                                    </a>
                                    <a href="/AdminNotification/DeleteNotification/@item.NotificationId" title="Sil" class="inline-flex items-center justify-center w-7 h-7 bg-red-500/10 text-red-400 hover:bg-red-500/20 rounded-md text-xs transition-all-custom" onclick="return confirm('Bu bildirimi silmek istediğinizden emin misiniz?')">
                                        <i class="mdi mdi-delete"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div id="emptyState" class="hidden p-12 text-center text-gray-500">
            <i class="mdi mdi-bell-off-outline text-5xl mb-3 block opacity-40"></i>
            <p class="text-sm font-medium">Arama kriterlerine uygun bildirim bulunamadı.</p>
        </div>

        @if (!Model.Any())
        {
            <div class="p-12 text-center text-gray-500">
                <i class="mdi mdi-bell-outline text-5xl mb-3 block opacity-30"></i>
                <p class="text-sm font-medium">Henüz bir bildirim eklenmemiş.</p>
                <a href="/AdminNotification/CreateNotification" class="mt-4 inline-flex items-center gap-2 bg-accent-blue/10 text-accent-blue hover:bg-accent-blue/20 px-4 py-2 rounded-lg text-sm font-medium transition-all-custom">
                    <i class="mdi mdi-plus"></i> İlk bildirimi ekle
                </a>
            </div>
        }

        <div class="px-5 py-3.5 border-t border-gray-800 flex items-center justify-between flex-wrap gap-3">
            <p id="paginationInfo" class="text-xs text-gray-500"></p>
            <div id="paginationControls" class="flex items-center gap-1"></div>
        </div>

    </div>
</div>

<div id="previewModal" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 hidden items-center justify-center p-4">
    <div class="bg-dark-bg-card border border-gray-700 rounded-2xl shadow-2xl w-full max-w-lg">
        <div class="flex items-center justify-between p-5 border-b border-gray-800">
            <div class="flex items-center gap-3">
                <div id="modalIcon" class="w-9 h-9 rounded-lg flex items-center justify-center">
                    <i class="mdi mdi-bell text-base"></i>
                </div>
                <div>
                    <h3 id="modalTitle" class="text-sm font-bold text-white leading-tight"></h3>
                    <span id="modalType" class="text-xs text-gray-500"></span>
                </div>
            </div>
            <button onclick="closePreview()" class="w-8 h-8 rounded-lg bg-gray-800 hover:bg-gray-700 text-gray-400 hover:text-white transition-all-custom flex items-center justify-center">
                <i class="mdi mdi-close text-sm"></i>
            </button>
        </div>
        <div class="p-5 space-y-4">
            <div>
                <p class="text-xs text-gray-500 uppercase tracking-wider font-semibold mb-1.5">İçerik</p>
                <p id="modalContent" class="text-sm text-gray-300 leading-relaxed"></p>
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <p class="text-xs text-gray-500 uppercase tracking-wider font-semibold mb-1.5">E-posta</p>
                    <p id="modalEmail" class="text-sm text-accent-blue break-all"></p>
                </div>
                <div>
                    <p class="text-xs text-gray-500 uppercase tracking-wider font-semibold mb-1.5">Durum</p>
                    <div id="modalStatus"></div>
                </div>
            </div>
        </div>
        <div class="px-5 pb-5 flex gap-2 justify-end">
            <a id="modalEditBtn" href="#" class="inline-flex items-center gap-1.5 bg-blue-500/10 hover:bg-blue-500/20 text-blue-400 px-4 py-2 rounded-lg text-xs font-bold transition-all-custom">
                <i class="mdi mdi-pencil"></i> Düzenle
            </a>
            <button onclick="closePreview()" class="inline-flex items-center gap-1.5 bg-gray-700 hover:bg-gray-600 text-gray-300 px-4 py-2 rounded-lg text-xs font-bold transition-all-custom">
                Kapat
            </button>
        </div>
    </div>
</div>

<script>
    const ROWS_PER_PAGE = 10;
    let currentPage = 1;
    let currentRows = [];

    const searchInput = document.getElementById('searchInput');
    const typeFilter = document.getElementById('typeFilter');
    const statusFilter = document.getElementById('statusFilter');
    const tableBody = document.getElementById('notifTableBody');
    const emptyState = document.getElementById('emptyState');
    const allRows = Array.from(document.querySelectorAll('.notif-row'));

    function filterRows() {
        const q = searchInput.value.toLowerCase();
        const type = typeFilter.value;
        const status = statusFilter.value;
        currentRows = allRows.filter(row => {
            const matchQ = !q || row.dataset.title.includes(q) || row.dataset.content.includes(q) || row.dataset.email.includes(q);
            const matchType = !type || row.dataset.type === type;
            const matchStatus = !status || row.dataset.status === status;
            return matchQ && matchType && matchStatus;
        });
        currentPage = 1;
        renderPage();
    }

    function renderPage() {
        allRows.forEach(r => r.style.display = 'none');
        const start = (currentPage - 1) * ROWS_PER_PAGE;
        const pageRows = currentRows.slice(start, start + ROWS_PER_PAGE);
        pageRows.forEach(r => r.style.display = '');
        emptyState.classList.toggle('hidden', currentRows.length > 0);
        renderPagination();
    }

    function renderPagination() {
        const total = currentRows.length;
        const totalPages = Math.max(1, Math.ceil(total / ROWS_PER_PAGE));
        const start = total === 0 ? 0 : (currentPage - 1) * ROWS_PER_PAGE + 1;
        const end = Math.min(currentPage * ROWS_PER_PAGE, total);
        document.getElementById('paginationInfo').textContent = total === 0 ? 'Sonuç bulunamadı' : `${start}–${end} / ${total} kayıt`;

        const ctrl = document.getElementById('paginationControls');
        ctrl.innerHTML = '';

        const btnClass = 'px-2.5 py-1 rounded text-xs font-medium transition-all-custom ';
        const addBtn = (label, page, disabled, active) => {
            const b = document.createElement('button');
            b.innerHTML = label;
            b.disabled = disabled;
            b.className = btnClass + (active ? 'bg-accent-blue text-white' : 'bg-gray-800 text-gray-400 hover:bg-gray-700 disabled:opacity-30 disabled:cursor-not-allowed');
            b.onclick = () => { currentPage = page; renderPage(); };
            ctrl.appendChild(b);
        };

        addBtn('<i class="mdi mdi-chevron-left"></i>', currentPage - 1, currentPage === 1, false);
        for (let i = 1; i <= totalPages; i++) {
            if (totalPages <= 7 || i === 1 || i === totalPages || Math.abs(i - currentPage) <= 1) {
                addBtn(i, i, false, i === currentPage);
            } else if (Math.abs(i - currentPage) === 2) {
                const span = document.createElement('span');
                span.textContent = '…';
                span.className = 'px-1 text-gray-600 text-xs';
                ctrl.appendChild(span);
            }
        }
        addBtn('<i class="mdi mdi-chevron-right"></i>', currentPage + 1, currentPage === totalPages, false);
    }

    searchInput.addEventListener('input', filterRows);
    typeFilter.addEventListener('change', filterRows);
    statusFilter.addEventListener('change', filterRows);

    function resetFilters() {
        typeFilter.value = '';
        statusFilter.value = '';
        filterRows();
    }

    document.getElementById('selectAll').addEventListener('change', function () {
        const visibleChecks = Array.from(document.querySelectorAll('.notif-row:not([style*="none"]) .row-check'));
        visibleChecks.forEach(c => c.checked = this.checked);
        updateBulkBar();
    });

    document.addEventListener('change', function (e) {
        if (e.target.classList.contains('row-check')) updateBulkBar();
    });

    function updateBulkBar() {
        const checked = document.querySelectorAll('.row-check:checked');
        const bar = document.getElementById('bulkBar');
        bar.classList.toggle('hidden', checked.length === 0);
        if (checked.length > 0) document.getElementById('selectedCount').textContent = checked.length + ' öğe seçildi';
    }

    function clearSelection() {
        document.querySelectorAll('.row-check, #selectAll').forEach(c => c.checked = false);
        updateBulkBar();
    }

    function bulkDelete() {
        const ids = Array.from(document.querySelectorAll('.row-check:checked')).map(c => c.dataset.id);
        if (!ids.length) return;
        if (!confirm(ids.length + ' bildirimi silmek istediğinize emin misiniz?')) return;
        ids.forEach(id => { window.location.href = '/AdminNotification/DeleteNotification/' + id; });
    }

    function openPreview(id, title, content, email, type, isRead) {
        document.getElementById('modalTitle').textContent = title;
        document.getElementById('modalContent').textContent = content;
        document.getElementById('modalEmail').textContent = email || '-';
        document.getElementById('modalType').textContent = type;
        document.getElementById('modalEditBtn').href = '/AdminNotification/UpdateNotification/' + id;
        const icon = document.getElementById('modalIcon');
        icon.className = 'w-9 h-9 rounded-lg flex items-center justify-center ' + (isRead === true || isRead === 'true' ? 'bg-green-500/10' : 'bg-yellow-500/10');
        icon.querySelector('i').className = 'mdi mdi-bell text-base ' + (isRead === true || isRead === 'true' ? 'text-green-400' : 'text-yellow-400');
        const statusEl = document.getElementById('modalStatus');
        statusEl.innerHTML = (isRead === true || isRead === 'true')
            ? '<span class="inline-flex items-center gap-1 bg-green-500/10 text-green-400 px-2 py-0.5 rounded-full text-xs font-medium"><i class="mdi mdi-check-circle text-xs"></i> Okundu</span>'
            : '<span class="inline-flex items-center gap-1 bg-yellow-500/10 text-yellow-400 px-2 py-0.5 rounded-full text-xs font-medium"><i class="mdi mdi-clock-outline text-xs"></i> Okunmadı</span>';
        const modal = document.getElementById('previewModal');
        modal.classList.remove('hidden');
        modal.classList.add('flex');
    }

    function closePreview() {
        const modal = document.getElementById('previewModal');
        modal.classList.add('hidden');
        modal.classList.remove('flex');
    }

    document.getElementById('previewModal').addEventListener('click', function (e) {
        if (e.target === this) closePreview();
    });

    function sortTable(key) {
        const asc = this._sortState !== key + '_asc';
        this._sortState = asc ? key + '_asc' : key + '_desc';
        currentRows.sort((a, b) => {
            let av = a.dataset[key === 'title' ? 'title' : key === 'type' ? 'type' : 'status'];
            let bv = b.dataset[key === 'title' ? 'title' : key === 'type' ? 'type' : 'status'];
            return asc ? av.localeCompare(bv) : bv.localeCompare(av);
        });
        renderPage();
    }

    filterRows();
</script>