@using QuickStart.WebUI.Dtos.Notification
@using QuickStart.WebUI.Dtos.NotificationTypes
@model CreateNotificationWithNotificationTypeDto

@{
	ViewData["Title"] = "CreateNotification";
	Layout = "~/Views/_AdminLayout/Index.cshtml";
	var notificationTypes = ViewBag.NotificationTypes as List<ResultNotificationTypeDto> ?? new();
}

<div class="max-w-4xl mx-auto mt-2">
	<div class="bg-dark-bg-card rounded-custom border border-gray-800 shadow-xl overflow-hidden">

		<div class="p-6 border-b border-gray-800 flex justify-between items-center flex-wrap gap-4">
			<div>
				<h2 class="text-xl font-bold text-white">Yeni Bildirim Ekle</h2>
				<p class="text-sm text-gray-400 mt-1">Platforma yeni bir bildirim oluşturun.</p>
			</div>
			<a href="/AdminNotification/Index" class="inline-flex items-center gap-2 bg-gray-800 hover:bg-gray-700 text-gray-300 px-4 py-2 rounded-custom transition-all-custom text-sm font-medium border border-gray-700">
				<i class="mdi mdi-arrow-left"></i> Listeye Dön
			</a>
		</div>

		<div class="p-6">
			<form method="post" class="space-y-6">

				<div>
					<label asp-for="Title" class="block text-sm font-medium text-gray-400 mb-2">Başlık</label>
					<input type="text" asp-for="Title" class="w-full bg-dark-bg-deep border border-gray-700 rounded-lg px-4 py-2.5 text-sm text-gray-300 focus:ring-2 focus:ring-accent-blue focus:border-accent-blue transition-all-custom outline-none" placeholder="Bildirim başlığı..." required />
				</div>

				<div>
					<label asp-for="Content" class="block text-sm font-medium text-gray-400 mb-2">İçerik</label>
					<textarea asp-for="Content" rows="4" class="w-full bg-dark-bg-deep border border-gray-700 rounded-lg px-4 py-2.5 text-sm text-gray-300 focus:ring-2 focus:ring-accent-blue focus:border-accent-blue transition-all-custom outline-none" placeholder="Bildirim içeriğini girin..." required></textarea>
				</div>

				<div>
					<label asp-for="Email" class="block text-sm font-medium text-gray-400 mb-2">E-posta</label>
					<input type="email" asp-for="Email" class="w-full bg-dark-bg-deep border border-gray-700 rounded-lg px-4 py-2.5 text-sm text-gray-300 focus:ring-2 focus:ring-accent-blue focus:border-accent-blue transition-all-custom outline-none" placeholder="ornek@mail.com" required />
				</div>

				<div>
					<label asp-for="NotificationTypeName" class="block text-sm font-medium text-gray-400 mb-2">Bildirim Türü</label>
					<select asp-for="NotificationTypeName" class="w-full bg-dark-bg-deep border border-gray-700 rounded-lg px-4 py-2.5 text-sm text-gray-300 focus:ring-2 focus:ring-accent-blue focus:border-accent-blue transition-all-custom outline-none" required>
						<option value="" disabled selected>-- Tür Seçiniz --</option>
						@foreach (var type in notificationTypes)
						{
							<option value="@type.Name">@type.Name</option>
						}
					</select>
				</div>

				<div class="flex items-center gap-3">
					<input type="checkbox" asp-for="IsRead" class="w-4 h-4 rounded border-gray-700 bg-dark-bg-deep text-accent-blue focus:ring-accent-blue" />
					<label asp-for="IsRead" class="text-sm font-medium text-gray-400">Okundu olarak işaretle</label>
				</div>

				<div class="pt-4 border-t border-gray-800 flex justify-end">
					<button type="submit" class="inline-flex items-center gap-2 bg-accent-blue hover:bg-blue-600 text-white px-6 py-2.5 rounded-lg transition-all-custom text-sm font-medium shadow-lg shadow-blue-500/30">
						<i class="mdi mdi-content-save"></i> Kaydet
					</button>
				</div>

			</form>
		</div>

	</div>
</div>
