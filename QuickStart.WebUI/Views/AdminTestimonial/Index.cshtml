@model List<QuickStart.WebUI.Dtos.Testimonials.ResultTestimonialDto>

@{
	ViewData["Title"] = "Index";
	Layout = "~/Views/_AdminLayout/Index.cshtml";
}

<div class="col-lg-12 grid-margin stretch-card">
	<div class="card">
		<div class="card-body">
			<h4 class="card-title">Müşteriler</h4>
			<p class="card-description">
				Müşteri<code>Listesi</code>
			</p>
			<div class="table-responsive">
				<table class="table table-striped">
					<thead>
						<tr>
							<th>Resmi</th>
							<th>Adı</th>
							<th>Puanı</th>
							<th>mesleği</th>
							<th>Yorumu</th>
							<th>Sil</th>
							<th>Güncelle</th>
						</tr>
					</thead>
					<tbody>
						@foreach (var item in Model)
						{
							<tr>
								<td class="py-1">
									<img src=@item.ImageUrl alt="image" />
								</td>
								<td>@item.FullName</td>
								<td>@item.Rate</td>
								<td>@item.Title</td>
								<td>@item.Description</td>
								<td>May 15, 2015</td>
								<td><a href="/AdminTestimonial/DeleteTestimonial/@item.Id" class="btn btn-danger">Sil</a></td>
								<td><a href="/AdminTestimonial/UpdateTestimonial/@item.Id" class="btn btn-success">Güncelle</a></td>
							</tr>
						}


					</tbody>
				</table>
				<a href="/AdminTestimonial/UpdateTestimonial" class="btn btn-success">Yeni Müşteri Ekleme Sayfası</a>
			</div>
		</div>
	</div>
</div>