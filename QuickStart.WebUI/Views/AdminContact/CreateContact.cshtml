@using QuickStart.WebUI.Dtos.Contacts
@model CreateContactsDto

@{
	ViewData["Title"] = "CreateContact";
	Layout = "~/Views/_AdminLayout/Index.cshtml";
}

<div class="max-w-4xl mx-auto mt-2">
	<div class="bg-dark-bg-card rounded-custom border border-gray-800 shadow-xl overflow-hidden">

		<div class="p-6 border-b border-gray-800 flex justify-between items-center flex-wrap gap-4">
			<div>
				<h2 class="text-xl font-bold text-white">Yeni İletişim Bilgisi Ekle</h2>
				<p class="text-sm text-gray-400 mt-1">Platforma yeni bir iletişim bilgisi oluşturun.</p>
			</div>
			<a href="/AdminContact/Index" class="inline-flex items-center gap-2 bg-gray-800 hover:bg-gray-700 text-gray-300 px-4 py-2 rounded-custom transition-all-custom text-sm font-medium border border-gray-700">
				<i class="mdi mdi-arrow-left"></i> Listeye Dön
			</a>
		</div>

		<div class="p-6">
			<form method="post" class="space-y-6">

				<div>
					<label asp-for="Address" class="block text-sm font-medium text-gray-400 mb-2">Adres</label>
					<input type="text" asp-for="Address" class="w-full bg-dark-bg-deep border border-gray-700 rounded-lg px-4 py-2.5 text-sm text-gray-300 focus:ring-2 focus:ring-accent-blue focus:border-accent-blue transition-all-custom outline-none" placeholder="Örn: Atatürk Cad. No:1, İstanbul" required />
				</div>

				<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
					<div>
						<label asp-for="PhoneNumber" class="block text-sm font-medium text-gray-400 mb-2">Telefon Numarası</label>
						<input type="text" asp-for="PhoneNumber" class="w-full bg-dark-bg-deep border border-gray-700 rounded-lg px-4 py-2.5 text-sm text-gray-300 focus:ring-2 focus:ring-accent-blue focus:border-accent-blue transition-all-custom outline-none" placeholder="+90 555 000 00 00" required />
					</div>
					<div>
						<label asp-for="Email" class="block text-sm font-medium text-gray-400 mb-2">E-Posta</label>
						<input type="email" asp-for="Email" class="w-full bg-dark-bg-deep border border-gray-700 rounded-lg px-4 py-2.5 text-sm text-gray-300 focus:ring-2 focus:ring-accent-blue focus:border-accent-blue transition-all-custom outline-none" placeholder="info@ornek.com" required />
					</div>
				</div>

				<div>
					<label asp-for="MapUrl" class="block text-sm font-medium text-gray-400 mb-2">Harita Linki</label>
					<input type="text" asp-for="MapUrl" class="w-full bg-dark-bg-deep border border-gray-700 rounded-lg px-4 py-2.5 text-sm text-gray-300 focus:ring-2 focus:ring-accent-blue focus:border-accent-blue transition-all-custom outline-none" placeholder="https://maps.google.com/..." />
				</div>

				<div class="pt-4 border-t border-gray-800 flex justify-end">
					<button type="submit" class="inline-flex items-center gap-2 bg-accent-blue hover:bg-blue-600 text-white px-6 py-2.5 rounded-lg transition-all-custom text-sm font-medium shadow-lg shadow-blue-500/30">
						<i class="mdi mdi-content-save"></i> Kaydet
					</button>
				</div>

			</form>
		</div>

	</div>
</div>
