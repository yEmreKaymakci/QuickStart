@{
	Layout = null;
}

<!DOCTYPE html>
<html lang="en">

@await Component.InvokeAsync("_AdminLayoutHeadComponentPartial")

<body class="flex h-screen overflow-hidden">
	@await Component.InvokeAsync("_AdminLayoutSidebarComponentPartial")

	<main class="flex-1 flex flex-col overflow-hidden">

		@await Component.InvokeAsync("_AdminLayoutNavbarComponentPartial")

		<div class="flex-1 overflow-y-auto p-6 md:p-8 space-y-6">
			@RenderBody()
		</div>

	</main>

	@await Component.InvokeAsync("_AdminLayoutScriptComponentPartial")

	@await RenderSectionAsync("Scripts", required: false)

	<div id="globalTextModal" class="fixed inset-0 z-50 hidden flex items-center justify-center bg-black/60 backdrop-blur-sm transition-opacity">
		<div class="bg-dark-bg-card border border-gray-800 rounded-custom shadow-2xl w-full max-w-lg mx-4 transform transition-all">

			<div class="flex justify-between items-center p-5 border-b border-gray-800">
				<h3 id="globalModalTitle" class="text-lg font-bold text-white">Detay</h3>
				<button id="closeGlobalModalBtn" class="text-gray-400 hover:text-red-400 transition-colors">
					<i class="mdi mdi-close text-2xl"></i>
				</button>
			</div>

			<div class="p-5 max-h-[60vh] overflow-y-auto custom-scrollbar">
				<p id="globalModalContent" class="text-gray-300 text-sm leading-relaxed break-words"></p>
			</div>

			<div class="p-4 border-t border-gray-800 text-right">
				<button id="closeGlobalModalBtn2" class="bg-gray-800 hover:bg-gray-700 text-white px-4 py-2 rounded-md text-sm font-medium transition-colors">
					Kapat
				</button>
			</div>

		</div>
	</div>
</body>
</html>