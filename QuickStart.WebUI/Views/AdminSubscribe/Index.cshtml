@using QuickStart.WebUI.Dtos.Subscribes
@model List<ResultSubscribeDto>

@{
	ViewData["Title"] = "Index";
	Layout = "~/Views/_AdminLayout/Index.cshtml";
}

<div class="bg-dark-bg-card rounded-custom border border-gray-800 shadow-xl overflow-hidden">

	<div class="p-6 border-b border-gray-800 flex justify-between items-center flex-wrap gap-4">
		<div>
			<h2 class="text-xl font-bold text-white">Abone Yönetimi</h2>
			<p class="text-sm text-gray-400 mt-1">Platforma abone olan e-posta listesini buradan yönetebilirsiniz.</p>
		</div>
		<a href="/AdminSubscribe/CreateSubscribe" class="inline-flex items-center gap-2 bg-accent-blue hover:bg-blue-600 text-white px-4 py-2 rounded-custom transition-all-custom text-sm font-medium shadow-lg shadow-blue-500/30">
			<i class="mdi mdi-plus"></i> Yeni Abone Ekle
		</a>
	</div>

	<div class="overflow-x-auto">
		<table class="w-full text-left whitespace-nowrap">
			<thead>
				<tr class="text-gray-500 text-xs font-bold uppercase tracking-wider bg-black/20">
					<th class="px-6 py-4">#</th>
					<th class="px-6 py-4">E-Posta</th>
					<th class="px-6 py-4 text-right">İşlemler</th>
				</tr>
			</thead>
			<tbody class="divide-y divide-gray-800">
				@foreach (var item in Model)
				{
					<tr class="hover:bg-white/5 transition-all-custom">
						<td class="px-6 py-4 text-sm text-gray-400">@item.Id</td>
						<td class="px-6 py-4 text-sm font-medium text-white">@item.Email</td>
						<td class="px-6 py-4 text-right space-x-2">
							<a href="/AdminSubscribe/UpdateSubscribe/@item.Id" class="inline-flex items-center justify-center bg-green-500/10 text-green-500 hover:bg-green-500/20 px-3 py-1.5 rounded-md text-xs font-bold transition-all-custom">
								<i class="mdi mdi-pencil mr-1"></i> Güncelle
							</a>
							<a href="/AdminSubscribe/DeleteSubscribe/@item.Id" class="inline-flex items-center justify-center bg-red-500/10 text-red-400 hover:bg-red-500/20 px-3 py-1.5 rounded-md text-xs font-bold transition-all-custom">
								<i class="mdi mdi-delete mr-1"></i> Sil
							</a>
						</td>
					</tr>
				}
			</tbody>
		</table>
	</div>

	@if (!Model.Any())
	{
		<div class="p-8 text-center text-gray-500">
			<i class="mdi mdi-database-outline text-4xl mb-2"></i>
			<p>Henüz abone kaydı bulunmuyor.</p>
		</div>
	}
</div>
