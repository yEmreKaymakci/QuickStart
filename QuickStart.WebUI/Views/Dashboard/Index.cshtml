@{
	ViewData["Title"] = "Index";
	Layout = "~/Views/_AdminLayout/Index.cshtml";
}

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
	<div class="bg-dark-bg-card p-6 rounded-custom border border-gray-800 shadow-xl">
		<div class="flex justify-between items-start">
			<div class="p-3 bg-blue-500/10 rounded-lg">
				<i class="mdi mdi-account-multiple text-accent-blue text-2xl"></i>
			</div>
			<span class="text-green-500 text-sm font-medium flex items-center">
				<i class="mdi mdi-trending-up mr-1"></i> +12%
			</span>
		</div>
		<h3 class="mt-4 text-gray-400 text-sm font-medium">Toplam Müşteri</h3>
		<p class="text-3xl font-bold mt-1 text-white">1,284</p>
	</div>
</div>

<div class="bg-dark-bg-card p-6 rounded-custom border border-gray-800 shadow-xl">
	<div class="flex items-center justify-between mb-6">
		<h2 class="text-xl font-bold text-white">Büyüme Analizi</h2>
	</div>
	<div class="h-[400px] w-full">
		<canvas id="growthChart"></canvas>
	</div>
</div>
<!-- Recent Messages Table -->
<div class="bg-dark-bg-card rounded-custom border border-gray-800 shadow-xl overflow-hidden">
