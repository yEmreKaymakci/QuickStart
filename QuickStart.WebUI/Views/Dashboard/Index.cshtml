					<td class="px-6 py-4">
						<span class="px-2.5 py-1 text-[11px] font-bold rounded-full bg-blue-500/10 text-accent-blue uppercase tracking-wider">Pending</span>
					</td>
					<td class="px-6 py-4 text-right">
						<button class="text-gray-400 hover:text-white mx-2"><i class="mdi mdi-eye"></i></button>
						<button class="text-gray-400 hover:text-red-400 mx-2"><i class="mdi mdi-delete"></i></button>
					</td>
				</tr>
			</tbody>
		</table>
	</div>
</div>

@section Scripts {
	<script>
		document.addEventListener('DOMContentLoaded', function() {
			const ctx = document.getElementById('growthChart').getContext('2d');

			const blueGradient = ctx.createLinearGradient(0, 0, 0, 400);
			blueGradient.addColorStop(0, 'rgba(59, 130, 246, 0.4)');
			blueGradient.addColorStop(1, 'rgba(59, 130, 246, 0)');

			const purpleGradient = ctx.createLinearGradient(0, 0, 0, 400);
			purpleGradient.addColorStop(0, 'rgba(168, 85, 247, 0.4)');
			purpleGradient.addColorStop(1, 'rgba(168, 85, 247, 0)');

			new Chart(ctx, {
				type: 'line',
				data: {
					labels: ['Pzt', 'Sal', 'Çar', 'Per', 'Cum', 'Cmt', 'Paz'],
					datasets: [
						{
							label: 'Ziyaretçiler',
							data: [31, 40, 28, 51, 42, 109, 100],
							borderColor: '#3b82f6',
							backgroundColor: blueGradient,
							fill: true,
							tension: 0.4,
							borderWidth: 3,
							pointRadius: 4,
							pointBackgroundColor: '#3b82f6',
						},
						{
							label: 'Aktif Kullanıcılar',
							data: [11, 32, 45, 32, 34, 52, 41],
							borderColor: '#a855f7',
							backgroundColor: purpleGradient,
							fill: true,
							tension: 0.4,
							borderWidth: 3,
							pointRadius: 4,
							pointBackgroundColor: '#a855f7',
						}
					]
				},
				options: {
					responsive: true,
					maintainAspectRatio: false,
					plugins: {
						legend: { labels: { color: '#9ca3af', font: { size: 12 } } }
					},
					scales: {
						y: {
							grid: { color: 'rgba(75, 85, 99, 0.2)', drawBorder: false },
							ticks: { color: '#6b7280' }
						},
						x: {
							grid: { display: false },
							ticks: { color: '#6b7280' }
						}
					}
				}
			});
		});
	</script>
}