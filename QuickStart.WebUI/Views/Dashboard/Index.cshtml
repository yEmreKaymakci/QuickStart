							<div>
								<p class="text-sm font-medium text-white">Johnathan Smith</p>
								<p class="text-xs text-gray-500">jsmith@example.com</p>
							</div>
						</div>
					</td>
					<td class="px-6 py-4 text-sm text-gray-300">Technical Inquiry regarding API</td>
					<td class="px-6 py-4 text-sm text-gray-400">Oct 24, 2023</td>
					<td class="px-6 py-4">
						<span class="px-2.5 py-1 text-[11px] font-bold rounded-full bg-blue-500/10 text-accent-blue uppercase tracking-wider">Pending</span>
					</td>
					<td class="px-6 py-4 text-right">
						<button class="text-gray-400 hover:text-white mx-2"><i class="mdi mdi-eye"></i></button>
						<button class="text-gray-400 hover:text-red-400 mx-2"><i class="mdi mdi-delete"></i></button>
					</td>
				</tr>
				<!-- Row 2 -->
				<tr class="hover:bg-white/5 transition-all-custom">
					<td class="px-6 py-4">
						<div class="flex items-center gap-3">
							<img alt="User" class="w-8 h-8 rounded-full" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDGfxoQ6Eh89_hIbLFIorZ6D8HSjE8AUiUnL1HuVwIKsLBjApQziwC8gdmGr927w6vPjbarJ24A_swiw4QxQQEIFS0qESgCOFWk32Y4F_JF_nq-q6RsGNHGnOHMe3hTWtXfNj1jKsdSrnJGWoERjQ4H4_7pSHJ39agPGAycJ5K8b8LsMg3-g4CCwH6HfgkQnDNTREBZIzXwSjIgpI5D3T_p_BV4xFh0ddWPqfLpWZ8jqVDF19QV1x5QYwphXPVVsW11TeftrDsY-WKU" />
