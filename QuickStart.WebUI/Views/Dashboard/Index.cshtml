					<td class="px-6 py-4 text-right">
						<button class="text-gray-400 hover:text-white mx-2"><i class="mdi mdi-eye"></i></button>
						<button class="text-gray-400 hover:text-red-400 mx-2"><i class="mdi mdi-delete"></i></button>
					</td>
				</tr>
				<!-- Row 3 -->
				<tr class="hover:bg-white/5 transition-all-custom">
					<td class="px-6 py-4">
						<div class="flex items-center gap-3">
							<img alt="User" class="w-8 h-8 rounded-full" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBdnlKv45CcBowoHTNgOvjdFhvMaUlrrfLPzLtWe9VzDVDypX-RAP9wnrGE6YF-skxoVdUDgwn9yhxFmWzkzhC1mJGxDJ1679_x79OrNMLuAtLU1ZjBOgAD3JVuMiCdY1gUwk4iNGv9ZHaqjRWH1SUfv8HJ9-GTMZ_7xBcD9w-vufdB1GxS0WTYNdMhjOttpDBKNitFeTIxa-Ud1S8pFtU4ZKsu_kYJTUvkYIURISbI4ryuWvdJF5I1PZvNkFcm6m1nZM8Y42YSfc2q" />
							<div>
								<p class="text-sm font-medium text-white">Mark Zucker</p>
								<p class="text-xs text-gray-500">mark@connect.com</p>
							</div>
						</div>
					</td>
					<td class="px-6 py-4 text-sm text-gray-300">Security feedback</td>
