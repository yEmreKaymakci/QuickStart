<section id="features" class="features section">

	<div class="container section-title" data-aos="fade-up">
		<h2>Özellikler</h2>
		<p>Platformumuzda bulundurduğumuz özellikler.</p>
	</div>

	<div class="container">
		<div class="row justify-content-between">

			<div class="col-lg-5 d-flex align-items-center">

				<ul class="nav nav-tabs" data-aos="fade-up" data-aos-delay="100">
					@{
						int navIndex = 0;
					} @foreach (var item in Model)
					{
						// İlk eleman ise "active show" class'ını ekle, değilse boş bırak
						string activeClass = (navIndex == 0) ? "active show" : "";

						<li class="nav-item">
							<a class="nav-link @activeClass" data-bs-toggle="tab" data-bs-target="#features-tab-@navIndex">
								<i class="@item.IconUrl"></i>
								<div>
									<h4 class="d-none d-lg-block">@item.Title</h4>
									<p>@item.Description</p>
								</div>
							</a>
						</li>

						navIndex++; // Her dönüşte sayacı artır
					}
				</ul>

			</div>

			<div class="col-lg-6">

				<div class="tab-content" data-aos="fade-up" data-aos-delay="200">

					@{
						int contentIndex = 0;
					} @foreach (var item in Model)
					{
						// İlk resim için "active show" ekliyoruz ki sayfa açılınca boş durmasın
						string activeClass = (contentIndex == 0) ? "active show" : "";

						<div class="tab-pane fade @activeClass" id="features-tab-@contentIndex">
							<img src="@Url.Content(item.ImageUrl)" alt="@item.Title" class="img-fluid">
						</div>

						contentIndex++;
					}

				</div>

			</div>

		</div>

	</div>

</section>