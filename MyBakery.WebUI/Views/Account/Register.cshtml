@using MyBakery.WebUI.Dtos.Auth
@model RegisterDto
@{
    Layout = null;
    ViewData["Title"] = "Yönetici Kaydı";
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Baker Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/MaterialDesign-Webfont/7.2.96/css/materialdesignicons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'dark-bg-deep': '#0d0d0d',
                        'dark-bg-card': '#1a1a1a',
                        'accent-blue': '#3b82f6',
                        'accent-amber': '#f59e0b',
                    },
                    borderRadius: { 'custom': '14px' },
                    fontFamily: { sans: ['Inter', 'sans-serif'] }
                }
            }
        }
    </script>
    <style>
        body { background-color: #0d0d0d; font-family: 'Inter', sans-serif; }
        .glow-blue { box-shadow: 0 0 40px rgba(59, 130, 246, 0.12); }
        .input-field {
            background: #111 !important;
            border: 1px solid #2a2a2a !important;
            color: #e5e7eb !important;
            -webkit-text-fill-color: #e5e7eb !important;
            border-radius: 10px;
            padding: 0.65rem 0.9rem 0.65rem 2.5rem;
            width: 100%;
            font-size: 0.875rem;
            transition: border-color 0.2s, box-shadow 0.2s;
            outline: none;
        }
        .input-field:focus {
            border-color: #3b82f6 !important;
            box-shadow: 0 0 0 3px rgba(59,130,246,0.15);
        }
        .input-field::placeholder { color: #4b5563 !important; }
        .input-field:-webkit-autofill,
        .input-field:-webkit-autofill:hover,
        .input-field:-webkit-autofill:focus {
            -webkit-box-shadow: 0 0 0px 1000px #111 inset !important;
            -webkit-text-fill-color: #e5e7eb !important;
            transition: background-color 5000s ease-in-out 0s;
        }
    </style>
</head>
<body class="min-h-screen flex items-center justify-center p-4">

    <div class="w-full max-w-md">

        <div class="flex justify-start mb-3">
            <a href="/Default/Index"
               class="inline-flex items-center gap-1.5 text-xs text-amber-400 hover:text-amber-300 bg-amber-500/10 hover:bg-amber-500/20 border border-amber-500/20 px-3 py-1.5 rounded-full transition-all duration-200 font-medium">
                <i class="mdi mdi-arrow-left text-sm"></i>
                Anasayfaya Dön
            </a>
        </div>

        <div class="text-center mb-8">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-gradient-to-br from-amber-500/20 to-blue-500/20 border border-amber-500/20 mb-4">
                <i class="mdi mdi-bread-slice text-amber-400 text-3xl"></i>
            </div>
            <h1 class="text-2xl font-bold text-white">Baker Admin</h1>
            <p class="text-sm text-gray-500 mt-1">Yeni yönetici hesabı oluşturun</p>
        </div>

        <div class="bg-dark-bg-card border border-gray-800 rounded-custom p-8 glow-blue">

            <form method="post" asp-action="Register" asp-controller="Account">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="mb-5 bg-red-500/10 border border-red-500/20 text-red-400 text-sm px-4 py-3 rounded-lg hidden [&:not(:empty)]:block"></div>

                <div class="space-y-4">

                    <div>
                        <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Kullanıcı Adı</label>
                        <div class="relative">
                            <i class="mdi mdi-account-outline absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-base"></i>
                            <input asp-for="Username" class="input-field" placeholder="admin" autocomplete="username" />
                        </div>
                        <span asp-validation-for="Username" class="text-red-400 text-xs mt-1 block"></span>
                    </div>

                    <div>
                        <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">E-posta</label>
                        <div class="relative">
                            <i class="mdi mdi-email-outline absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-base"></i>
                            <input asp-for="Email" class="input-field" placeholder="admin@firininiz.com" autocomplete="email" />
                        </div>
                        <span asp-validation-for="Email" class="text-red-400 text-xs mt-1 block"></span>
                    </div>

                    <div>
                        <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Şifre</label>
                        <div class="relative">
                            <i class="mdi mdi-lock-outline absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-base"></i>
                            <input asp-for="Password" class="input-field" placeholder="En az 6 karakter" autocomplete="new-password" />
                        </div>
                        <span asp-validation-for="Password" class="text-red-400 text-xs mt-1 block"></span>
                    </div>

                    <div>
                        <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Şifre Tekrar</label>
                        <div class="relative">
                            <i class="mdi mdi-lock-check-outline absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-base"></i>
                            <input asp-for="ConfirmPassword" class="input-field" placeholder="Şifrenizi tekrar girin" autocomplete="new-password" />
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-red-400 text-xs mt-1 block"></span>
                    </div>

                    <div class="pt-1">
                        <button type="submit"
                                class="w-full bg-accent-blue hover:bg-blue-500 active:bg-blue-700 text-white font-semibold py-2.5 rounded-xl transition-all duration-200 text-sm flex items-center justify-center gap-2 shadow-lg shadow-blue-500/20">
                            <i class="mdi mdi-account-plus text-base"></i>
                            Hesap Oluştur
                        </button>
                    </div>

                </div>
            </form>

        </div>

        <p class="text-center text-xs text-gray-500 mt-6">
            Zaten hesabınız var mı?
            <a href="/Account/Login" class="text-accent-blue hover:text-blue-400 font-medium transition-colors">Giriş yap</a>
        </p>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
