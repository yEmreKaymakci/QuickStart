@using MyBakery.WebUI.Dtos.Services
@model List<ResultServicesDto>
<section id="services" class="services section light-background">

	<!-- Section Title -->
	<div class="container section-title" data-aos="fade-up">
		<h2>Hizmetlerimiz</h2>
	</div><!-- End Section Title -->

    <div class="container">
        <div class="row gy-4">

            @{
                int index = 0;
            } @foreach (var item in Model)
            {
                // 1. ADIM: Sağlı Sollu Dizilim Mantığı
                // Eğer index çift sayıysa (0, 2, 4) farklı class, tek sayıysa farklı class ver.
                // Not: Kendi HTML'indeki class isimlerini buraya yazmalısın.
                string alignmentClass = (index % 2 == 0) ? "class-sol" : "class-sag";

                // 2. ADIM: İlk 6'dan Sonrasını Gizleme Mantığı
                // Index 6 veya daha büyükse (yani 7. eleman ve sonrası), "d-none" ve bizim kontrol edeceğimiz "extra-service" class'ını ekle.
                string displayClass = (index >= 6) ? "d-none extra-service" : "";

                <div class="col-lg-6 @alignmentClass @displayClass">
                    <div class="service-item">
                        @{
                            string sIconClass = item.IconUrl != null && item.IconUrl.Contains("bi ") ? item.IconUrl : "bi bi-" + item.IconUrl;
                        }
                        <i class="@sIconClass"></i>
                        <h3>@item.Title</h3>
                        <p>@item.Description</p>
                    </div>
                </div>
                index++;
            }
        </div>

        @if (Model.Count > 6)
        {
            <div class="text-center mt-4 text-center">
                <button id="toggleServicesBtn" class="btn btn-primary" onclick="toggleServices()">Daha Fazla Göster</button>
            </div>
        }
    </div>

</section>

